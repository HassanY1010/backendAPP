APP_NAME="Haraj App"
APP_ENV=production
APP_KEY=base64:CHANGE_ME_RUN_php_artisan_key_generate
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://your-backend-domain.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=classified_ads_db
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME

FILESYSTEM_DISK=supabase
QUEUE_CONNECTION=redis
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=CHANGE_ME
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# CORS: Add your production frontend URL
FRONTEND_URL=https://your-admin-panel-domain.com

SMS_GATEWAY_URL=https://sms.alawaeltec.com/MainServlet
SMS_ORG_NAME=CHANGE_ME
SMS_USER_NAME=CHANGE_ME
SMS_PASSWORD=CHANGE_ME

BROADCAST_DRIVER=pusher
PUSHER_APP_ID=CHANGE_ME
PUSHER_APP_KEY=CHANGE_ME
PUSHER_APP_SECRET=CHANGE_ME
PUSHER_APP_CLUSTER=CHANGE_ME

# Supabase Configuration
SUPABASE_URL=CHANGE_ME
# Use the Storage S3 Access Key ID from Supabase dashboard, not the project ref.
SUPABASE_STORAGE_KEY=CHANGE_ME
SUPABASE_STORAGE_SECRET=CHANGE_ME
SUPABASE_STORAGE_ENDPOINT=CHANGE_ME
SUPABASE_STORAGE_REGION=us-east-1
SUPABASE_STORAGE_BUCKET=uploads

# Sadad Payment Gateway
SADAD_MERCHANT_ID=CHANGE_ME
SADAD_API_KEY=CHANGE_ME
SADAD_SECRET=CHANGE_ME

# Admin Token TTL (hours)
ADMIN_TOKEN_TTL_HOURS=8
